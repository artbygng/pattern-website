---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const patterns = await getCollection('patterns');
const pattern = patterns.find(p => p.slug === 'painter')!;
const { Content } = await pattern.render();
const { title, tagline, coverImage, etsy_url, accentColor, images, details, playVideo, flipVideo, skillNotes, faq, customerQuotes } = pattern.data;
---

<BaseLayout
  title={`${title} Crochet Quiet Book Pattern`}
  description={tagline}
  ogImage={coverImage}
  accentColor={accentColor}
>

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <a href="/patterns" class="back-link">&larr; All patterns</a>
    </div>
  </div>

  <!-- Two-column product section -->
  <section class="product-section section-padding">
    <div class="container product-inner">

      <!-- Left: gallery -->
      <div class="product-gallery">
        {images.length > 1 && (
          <div class="gallery-thumbs">
            {images.map((src, i) => (
              <button
                class={`thumb-btn${i === 0 ? ' active' : ''}`}
                data-src={src}
                data-alt={`${title} — page ${i + 1}`}
                aria-label={`View page ${i + 1}`}
                type="button"
              >
                <img src={src} alt="" width="80" height="80" loading="lazy" />
              </button>
            ))}
          </div>
        )}
        <div class="gallery-main">
          <img
            id="gallery-main-img"
            src={images[0]}
            alt={`${title} — page 1`}
            width="700"
            height="700"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <!-- Right: info -->
      <div class="product-info">
        <p class="pattern-eyebrow">Crochet PDF Pattern</p>
        <h1 class="pattern-title">{title}</h1>
        <p class="pattern-tagline">{tagline}</p>

        {details.length > 0 && (
          <dl class="detail-list">
            {details.map(({ label, value }) => (
              <>
                <dt>{label}</dt>
                <dd>{value}</dd>
              </>
            ))}
          </dl>
        )}

        <a
          href={etsy_url}
          class="btn btn-accent btn-lg product-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get the pattern on Etsy &rarr;
        </a>
      </div>

    </div>
  </section>

  <!-- Book play video -->
  {playVideo && (
    <section class="pattern-play-video section-padding">
      <div class="container">
        <h2 class="section-heading">See it in action</h2>
        <div class="play-video-wrapper">
          {playVideo.startsWith('http') ? (
            <iframe
              src={playVideo}
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              title={`${title} quiet book — interactive play demo`}
            ></iframe>
          ) : (
            <video
              src={playVideo}
              controls
              playsinline
              preload="metadata"
              aria-label={`${title} quiet book — interactive play demo`}
            ></video>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Markdown content (full width) -->
  <section class="pattern-body section-padding">
    <div class="container">
      <div class="pattern-content prose">
        <Content />
      </div>
    </div>
  </section>

  <!-- PDF flip-through video -->
  <section class="pattern-video section-padding">
    <div class="container">
      <h2 class="section-heading">See it come together</h2>
      {flipVideo ? (
        <div class="video-wrapper">
          {flipVideo.startsWith('http') ? (
            <iframe
              src={flipVideo}
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              title={`${title} pattern PDF flip-through`}
            ></iframe>
          ) : (
            <video
              src={flipVideo}
              controls
              playsinline
              preload="metadata"
              aria-label={`${title} pattern PDF flip-through`}
            ></video>
          )}
        </div>
      ) : (
        <div class="video-placeholder">
          <div class="video-placeholder-icon">▶</div>
          <p class="video-placeholder-label">Flip-through video coming soon</p>
        </div>
      )}
    </div>
  </section>

  <!-- Honest skill framing -->
  {skillNotes && (
    <section class="pattern-skill section-padding">
      <div class="container">
        <h2 class="section-heading">How hard is it, really?</h2>
        <div class="skill-grid">
          <div class="skill-col skill-col--easy">
            <h3 class="skill-col-heading">The straightforward parts</h3>
            <ul class="skill-list">
              {skillNotes.easy.map(item => <li>{item}</li>)}
            </ul>
          </div>
          <div class="skill-col skill-col--patient">
            <h3 class="skill-col-heading">The parts that take patience</h3>
            <ul class="skill-list">
              {skillNotes.patient.map(item => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Mid-page CTA -->
  <div class="mid-cta">
    <div class="container mid-cta-inner">
      <p class="mid-cta-text">Ready to start? The full PDF is waiting for you.</p>
      <a
        href={etsy_url}
        class="btn btn-accent"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get this pattern on Etsy &rarr;
      </a>
    </div>
  </div>

  <!-- FAQ -->
  {faq.length > 0 && (
    <section class="pattern-faq section-padding">
      <div class="container faq-inner">
        <h2 class="section-heading">Questions & answers</h2>
        <dl class="faq-list">
          {faq.map(({ q, a }) => (
            <>
              <dt class="faq-q">{q}</dt>
              <dd class="faq-a">{a}</dd>
            </>
          ))}
        </dl>
      </div>
    </section>
  )}

  <!-- Customer reviews -->
  {customerQuotes.filter(c => c.quote).length > 0 && (
    <section class="pattern-ugc section-padding">
      <div class="container">
        <h2 class="section-heading">What makers are saying</h2>
        <div class="ugc-grid">
          {customerQuotes.filter(c => c.quote).map(({ quote, author, image, date }) => (
            <div class="ugc-card">
              <div class="ugc-top">
                <span class="ugc-stars" aria-label="5 stars">★★★★★</span>
                {date && <span class="ugc-date">{date}</span>}
              </div>
              <blockquote class="ugc-quote">
                <p>"{quote}"</p>
              </blockquote>
              {image && (
                <div class="ugc-maker-photo">
                  <img src={image} alt={`Finished ${title} made by ${author}`} />
                </div>
              )}
              <div class="ugc-author-row">
                <div class="ugc-avatar">
                  <span>{author.charAt(0)}</span>
                </div>
                <div class="ugc-author-info">
                  <span class="ugc-author-name">{author}</span>
                  <span class="ugc-source">Etsy review</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA strip -->
  <section class="cta-strip">
    <div class="container cta-strip-inner">
      <div class="cta-strip-text">
        <p class="cta-eyebrow">The pattern is ready when you are.</p>
        <p class="cta-sub">Download the PDF and start crocheting today.</p>
      </div>
      <a
        href={etsy_url}
        class="btn btn-accent btn-lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        Get the pattern on Etsy &rarr;
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const thumbBtns = document.querySelectorAll<HTMLButtonElement>('.thumb-btn');
  const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement;

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      thumbBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      mainImg.src = btn.dataset.src!;
      mainImg.alt = btn.dataset.alt!;
    });
  });
</script>

<style>
  /* ---- BREADCRUMB ---- */
  .breadcrumb-bar {
    background: var(--cream-alt);
    border-bottom: 1px solid var(--border);
    padding-block: var(--space-3);
  }

  .back-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--ink); }

  /* ---- TWO-COLUMN PRODUCT SECTION ---- */
  .product-section {
    background: var(--cream-alt);
  }

  .product-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 800px) {
    .product-inner {
      grid-template-columns: 55fr 45fr;
      gap: var(--space-16);
    }
  }

  /* ---- GALLERY ---- */
  .product-gallery {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-3);
    align-items: start;
  }

  .gallery-main {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--border);
    aspect-ratio: 1 / 1;
  }

  .gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.15s ease;
  }

  .gallery-thumbs {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .thumb-btn {
    width: 72px;
    height: 72px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    background: var(--border);
    flex-shrink: 0;
    transition: border-color 0.15s;
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-btn:hover { border-color: var(--ink-muted); }
  .thumb-btn.active { border-color: var(--accent); }

  /* ---- PRODUCT INFO ---- */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .pattern-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .pattern-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    line-height: 1.2;
  }

  .pattern-tagline {
    font-size: 1rem;
    color: var(--ink-muted);
    line-height: 1.65;
    margin: 0;
  }

  .detail-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2) var(--space-5);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-block: var(--space-4);
    margin: 0;
  }

  .detail-list dt {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
    white-space: nowrap;
    padding-top: 2px;
  }

  .detail-list dd {
    font-size: 0.95rem;
    color: var(--ink);
  }

  .product-cta {
    display: block;
    text-align: center;
    margin-top: var(--space-2);
  }

  /* ---- BODY (full width prose) ---- */
  .pattern-content {
    max-width: 72ch;
    margin-inline: auto;
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-10);
    margin-bottom: var(--space-5);
  }

  .prose :global(h2:first-child) { margin-top: 0; }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: var(--space-10);
  }

  /* ---- SHARED SECTION HEADING ---- */
  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 500;
    text-align: center;
    margin-bottom: var(--space-10);
    color: var(--ink);
  }

  /* ---- PLAY VIDEO ---- */
  .pattern-play-video {
    background: var(--ink);
  }

  .pattern-play-video .section-heading {
    color: var(--white);
  }

  .play-video-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    max-width: 860px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
  }

  .play-video-wrapper iframe,
  .play-video-wrapper video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ---- FLIP-THROUGH VIDEO ---- */
  .pattern-video { background: var(--cream-alt); }

  .video-wrapper {
    position: relative;
    aspect-ratio: 9 / 16;
    max-width: 380px;
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
  }

  .video-wrapper iframe,
  .video-wrapper video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-placeholder {
    max-width: 860px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    background: var(--cream-alt);
    border: 2px dashed var(--border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .video-placeholder-icon {
    font-size: 2.5rem;
    color: var(--border);
  }

  .video-placeholder-label {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--ink-muted);
    margin: 0;
  }

  /* ---- SKILL FRAMING ---- */
  .pattern-skill { background: var(--cream); }

  .skill-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 860px;
    margin: 0 auto;
  }

  @media (min-width: 680px) {
    .skill-grid { grid-template-columns: 1fr 1fr; gap: var(--space-10); }
  }

  .skill-col {
    background: var(--cream);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    border-top: 3px solid transparent;
  }

  .skill-col--easy { border-top-color: #7ab87a; }
  .skill-col--patient { border-top-color: var(--accent); }

  .skill-col-heading {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-5);
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .skill-list li {
    font-size: 0.95rem;
    color: var(--ink-muted);
    line-height: 1.6;
    padding-left: 1.2em;
    position: relative;
  }

  .skill-col--easy .skill-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #7ab87a;
    font-weight: 700;
    font-size: 0.8rem;
    top: 2px;
  }

  .skill-col--patient .skill-list li::before {
    content: "~";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  /* ---- MID-PAGE CTA ---- */
  .mid-cta {
    background: #E8D4DA;
    padding-block: var(--space-10);
  }

  .mid-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .mid-cta-text {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--ink);
    margin: 0;
  }

  /* ---- FAQ ---- */
  .pattern-faq { background: var(--cream); }

  .faq-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq-q {
    font-weight: 600;
    font-size: 1rem;
    color: var(--ink);
    padding: var(--space-5) 0 var(--space-2);
    border-top: 1px solid var(--border);
    margin: 0;
  }

  .faq-list dt:first-child { border-top: none; }

  .faq-a {
    font-size: 0.95rem;
    color: var(--ink-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-2);
    padding-bottom: var(--space-3);
  }

  /* ---- REVIEWS ---- */
  .pattern-ugc { background: var(--cream-alt); }

  .ugc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 600px) { .ugc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .ugc-grid { grid-template-columns: repeat(3, 1fr); } }

  .ugc-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ugc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .ugc-stars { color: #E8A020; font-size: 0.95rem; letter-spacing: 0.05em; }
  .ugc-date { font-size: 0.78rem; color: var(--ink-muted); white-space: nowrap; }

  .ugc-quote { margin: 0; flex: 1; }

  .ugc-quote p {
    font-size: 0.95rem;
    color: var(--ink-muted);
    line-height: 1.7;
    font-style: italic;
    max-width: none;
    margin: 0;
  }

  .ugc-author-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border);
  }

  .ugc-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--accent-light, #FAE8E5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ugc-avatar span { font-size: 1rem; font-weight: 600; color: var(--accent); line-height: 1; }

  .ugc-author-info { display: flex; flex-direction: column; gap: 2px; }
  .ugc-author-name { font-size: 0.875rem; font-weight: 600; color: var(--ink); }
  .ugc-source { font-size: 0.75rem; color: var(--ink-muted); }

  /* ---- CTA STRIP ---- */
  .cta-strip {
    background: var(--ink);
    padding-block: var(--space-12);
  }

  .cta-strip-inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .cta-eyebrow {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 500;
    color: var(--white);
    margin-bottom: var(--space-2);
    max-width: none;
  }

  .cta-sub {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: none;
    margin-bottom: 0;
  }
</style>
