---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { blogCategoryList } from '../../data/blogCategories';

const allPosts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
const sorted = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Gift guides, comparisons, and how-to answers for crochet quiet book patterns from Artbygng."
>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <p class="page-eyebrow">The Blog</p>
      <h1 class="page-title">Ideas, guides, and answers</h1>
      <p class="page-desc">
        Gift ideas, pattern comparisons, and everything you might want to know before
        (or while) making a quiet book of your own.
      </p>
    </div>
  </section>

  <!-- CATEGORY FILTER -->
  <section class="category-nav">
    <div class="container category-nav-inner">
      <a href="/blog" class="category-pill category-pill--active">All posts</a>
      {blogCategoryList.map(cat => (
        <a href={`/blog/category/${cat.slug}`} class="category-pill">{cat.label}</a>
      ))}
    </div>
  </section>

  <!-- POST GRID -->
  <section class="blog-section section-padding">
    <div class="container">
      {sorted.length > 0 ? (
        <div class="blog-grid">
          {sorted.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              coverImage={post.data.coverImage}
              category={post.data.category}
              pubDate={post.data.pubDate}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No posts yet — check back soon.</p>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding-block: var(--space-20) var(--space-12);
    text-align: center;
    background: var(--cream-alt);
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .page-header { padding-block: var(--space-12) var(--space-8); }
  }

  .page-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    max-width: 22ch;
    margin-inline: auto;
    margin-bottom: var(--space-5);
  }

  .page-desc {
    color: var(--ink-muted);
    font-size: 1.05rem;
    line-height: 1.72;
    max-width: 54ch;
    margin-inline: auto;
  }
</style>
