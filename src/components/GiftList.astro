---
interface Item {
  text: string;
  anchor?: string;
  thumbnail?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<ol class="gift-list">
  {items.map(item => (
    <li class="gift-list-item">
      {item.thumbnail && (
        <img src={item.thumbnail} alt="" class="gift-list-thumb" width="80" height="80" loading="lazy" />
      )}
      <span class="gift-list-text">
        {item.anchor ? <a href={item.anchor}>{item.text}</a> : item.text}
      </span>
    </li>
  ))}
</ol>

<style>
  .gift-list {
    list-style: decimal;
    padding-left: 1.4em;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .gift-list-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--ink-muted);
  }

  .gift-list .gift-list-thumb {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    margin: 0;
  }

  .gift-list-text a {
    color: var(--accent);
  }
</style>
