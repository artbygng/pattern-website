---
interface Props {
  title: string;
  tagline: string;
  slug: string;
  coverImage: string;
  etsy_url: string;
}

const { title, tagline, slug, coverImage, etsy_url } = Astro.props;
const detailUrl = `/patterns/${slug}`;
---

<article class="pattern-card">
  <a href={detailUrl} class="card-img-link" tabindex="-1" aria-hidden="true">
    <div class="card-img">
      {coverImage
        ? <>
            <img src={coverImage} alt={`${title} crochet quiet book pattern`} width="600" height="800" loading="lazy" class="card-cover-img" />
            <img src="/images/badge-crochet-pdf-pattern.png" alt="" aria-hidden="true" class="card-badge" width="438" height="438" />
          </>
        : <div class="img-placeholder card-img-placeholder">{title}<br />Cover photo</div>
      }
    </div>
  </a>

  <div class="card-body">
    <a href={detailUrl} class="card-title-link">
      <h2 class="card-title">{title}</h2>
    </a>
    <p class="card-tagline">{tagline}</p>

    <div class="card-actions">
      <a href={detailUrl} class="card-more-link">See details &rarr;</a>
      <a
        href={etsy_url}
        class="btn btn-accent btn-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        Shop on Etsy
      </a>
    </div>
  </div>
</article>

<style>
  .pattern-card {
    background: var(--cream);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .pattern-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(42, 40, 37, 0.09);
  }

  /* Image area */
  .card-img-link {
    display: block;
    overflow: hidden;
  }

  .card-img {
    aspect-ratio: 10 / 11;
    overflow: hidden;
    background: var(--cream-alt);
    position: relative;
  }

  .card-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    width: clamp(48px, 15%, 72px);
    height: auto;
    pointer-events: none;
  }

  .card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .pattern-card:hover .card-cover-img {
    transform: scale(1.03);
  }

  .card-img-placeholder {
    width: 100%;
    height: 100%;
    border-radius: 0;
    border: none;
    min-height: unset;
  }

  /* Body */
  .card-body {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .card-title-link {
    text-decoration: none;
    color: inherit;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }

  .card-title-link:hover .card-title {
    color: var(--accent);
  }

  .card-tagline {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.55;
    flex: 1;
    max-width: none;
  }

  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .card-more-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .card-more-link:hover {
    color: var(--ink);
  }
</style>
